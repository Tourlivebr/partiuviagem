---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import HeroModerno from '../components/HeroModerno.astro';
import CarrosselDestinos from '../components/CarrosselDestinos.astro';
import CarrosselDestinosInternacionais from '../components/CarrosselDestinosInternacionais.astro';
import Depoimentos from '../components/Depoimentos.astro';
import FormularioContato from '../components/FormularioContato.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout 
  title="Partiu Viagem - Agência de Viagens no Rio Grande do Sul"
  description="Descubra destinos incríveis no Brasil e no mundo com a Partiu Viagem. Pacotes turísticos, excursões e experiências inesquecíveis saindo do RS."
  image="/images/atacama-expedicao.jpg"
  keywords={["Agência de Viagens", "Excursões RS", "Turismo", "Pacotes de Viagem", "Viagens 2026", "Destinos Nacionais", "Destinos Internacionais"]}
>
  <Header />
  
  <!-- Seção Hero -->
  <HeroModerno />
  
  <!-- Seção de Destinos Nacionais -->
  <section id="destinos">
    <CarrosselDestinos />
  </section>

  <!-- Seção de Destinos Internacionais -->
  <section id="destinos-internacionais">
    <CarrosselDestinosInternacionais />
  </section>
  
  <!-- Seção Depoimentos -->
  <section id="depoimentos">
    <Depoimentos />
  </section>
  
  <!-- Seção Contato -->
  <section id="contato">
    <FormularioContato />
  </section>
  
  <!-- Footer -->
  <Footer />
</BaseLayout>